---
import Base from '../../layouts/Base.astro';
import Subscribe from '../../components/Subscribe.astro';
import { getCollection } from 'astro:content';
import { UI, fmtDate } from '../../config.js';

const lang = 'en';
const t = UI[lang];
const posts = (await getCollection('blog', ({ id, data }) => id.startsWith('en/') && !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Base title={`${t.brandMark} · ${t.brandName}`} description={t.heroDesc} lang={lang} path="/en/">
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">{t.heroEyebrow}</p>
      <h1>{t.heroTitle}</h1>
      <p>{t.heroDesc}</p>
    </div>
  </section>

  <section class="post-list">
    <div class="wrap">
      <p class="list-label">{t.latest}</p>
      {posts.map((post) => (
        <a href={`/en/blog/${post.slug.replace('en/', '')}/`} class="post-item">
          <p class="post-meta">{fmtDate(post.data.pubDate, lang)}</p>
          <h2 class="post-title">{post.data.title}</h2>
          <p class="post-desc">{post.data.description}</p>
        </a>
      ))}
      <Subscribe lang={lang} />
    </div>
  </section>
</Base>
