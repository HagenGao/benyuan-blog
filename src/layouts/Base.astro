---
import '../styles/global.css';
import { UI } from '../config.js';

const { title, description, lang = 'zh', path } = Astro.props;
const t = UI[lang];
const otherPath = t.otherLangPath(path);
---
<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="alternate" hreflang={lang === 'zh' ? 'en' : 'zh'} href={otherPath} />
    <!-- 中文衬线 + 无衬线网络字体 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;600&family=Noto+Serif+SC:wght@400;500;600&display=swap" rel="stylesheet" />
    <!-- 防止深浅主题切换闪烁 -->
    <script is:inline>
      const saved = localStorage.getItem('theme');
      if (saved) document.documentElement.dataset.theme = saved;
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a href={`/${lang}/`} class="brand">
          <span class="mark">{t.brandMark}</span> · {t.brandName}
        </a>
        <nav class="nav">
          <a href={`/${lang}/`}>{t.navBlog}</a>
          <a href={otherPath} class="tool-btn" title="切换语言 / Switch language" style="width:auto;padding:0 0.55rem;">{t.otherLang}</a>
          <button class="tool-btn" id="theme-toggle" title="切换主题 / Toggle theme" aria-label="Toggle theme">
            <span id="theme-icon">◐</span>
          </button>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="wrap">
        <p>© {new Date().getFullYear()} · {t.footerNote}</p>
        <div class="links">
          <a href="https://youtube.com/@gaohailu" target="_blank" rel="noopener">YouTube</a>
          <a href={otherPath}>{t.otherLang}</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      const root = document.documentElement;
      const icon = document.getElementById('theme-icon');
      const setIcon = () => { icon.textContent = root.dataset.theme === 'light' ? '☀' : '◐'; };
      setIcon();
      document.getElementById('theme-toggle').addEventListener('click', () => {
        root.dataset.theme = root.dataset.theme === 'light' ? 'dark' : 'light';
        localStorage.setItem('theme', root.dataset.theme);
        setIcon();
      });
    </script>
  </body>
</html>
